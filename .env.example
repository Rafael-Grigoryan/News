# Copy to .env and fill in. Used for local runs only.
# In GitHub Actions these come from repo Secrets instead.

# Required: from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Required: channel id. Public channel -> @your_channel_username
# Private channel -> numeric -100xxxxxxxxxx
TELEGRAM_CHAT_ID=@your_channel

# Optional: newsapi.org key. Leave empty to disable that source.
NEWSAPI_KEY=
